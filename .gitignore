# =============================================================================
# STC Logistics WMS — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Next.js build output
# -----------------------------------------------------------------------------
/.next/
/out/
/build/

# -----------------------------------------------------------------------------
# Environment variables — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
# Keep migration files and schema — exclude generated client (rebuilt on install)
prisma/generated/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
/coverage/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.DS_Store
*.pem
Thumbs.db

# -----------------------------------------------------------------------------
# Debug logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Local uploads / temp files (warehouse document storage)
# -----------------------------------------------------------------------------
/public/uploads/
/tmp/
