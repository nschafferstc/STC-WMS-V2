# =============================================================================
# STC Logistics WMS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase / Prisma — dual connection required for Vercel serverless
# -----------------------------------------------------------------------------

# DATABASE_URL: Supabase Transaction pooler (port 6543)
# Used for all runtime queries (Next.js API routes, Server Components).
# pgbouncer=true and connection_limit=1 are required for Vercel serverless functions.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Supabase direct connection (port 5432)
# Used by Prisma CLI for migrations only (prisma migrate dev / deploy).
# Do NOT use this URL in application code.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth — Application Authentication
# -----------------------------------------------------------------------------

# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# The canonical URL of your application
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email — Nodemailer SMTP (outbound notifications, BOL emails, alerts)
# -----------------------------------------------------------------------------

# Example for Gmail: smtp.gmail.com / 587
# Example for Outlook: smtp.office365.com / 587
# For production, consider Resend (smtp.resend.com) or SendGrid
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# The "From" address for outbound emails
SMTP_FROM="noreply@shipstc.com"

# -----------------------------------------------------------------------------
# Carrier APIs — Parcel Tracking (fill in for live tracking)
# -----------------------------------------------------------------------------

# FedEx Developer Portal: https://developer.fedex.com
FEDEX_API_KEY=""
FEDEX_API_SECRET=""
FEDEX_ACCOUNT_NUMBER=""

# UPS Developer Portal: https://developer.ups.com
UPS_API_KEY=""
UPS_CLIENT_ID=""
UPS_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Set to "true" to enable verbose Prisma query logging in development
PRISMA_QUERY_LOG="false"

# Default warehouse ID (used when the app operates in single-warehouse mode)
DEFAULT_WAREHOUSE_ID=""
